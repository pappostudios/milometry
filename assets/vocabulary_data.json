{
  "words": [
    { "id": 1000, "language": "hebrew", "term": "אָבְנַיִים", "translation": "מתקן מסתובב להכנת כלי חרס", "example": "הקדר יצר כד על האבניים." },
    { "id": 1001, "language": "hebrew", "term": "אוֹצֵר", "translation": "אחראי על המוצגים במוזיאון / שומר על דבר יקר", "example": "האוצר בחר את התמונות לתערוכה." },
    { "id": 1002, "language": "hebrew", "term": "אָחוּ", "translation": "כר דשא, שדה מרעה", "example": "הכבשים רעו בנחת באחו." },
    { "id": 1003, "language": "hebrew", "term": "אִחוּי", "translation": "חיבור חלקים, הכלבה", "example": "הרופא ביצע איחוי של הפצע." },
    { "id": 1004, "language": "hebrew", "term": "אִלּוּלֵא", "translation": "אם לא, אלמלא", "example": "אלולא עזרתך, לא הייתי מצליח." },
    { "id": 1005, "language": "hebrew", "term": "אֲלוּמָה", "translation": "חבילת שיבולים קצורות", "example": "החקלאים אספו אלומות בשדה." },
    { "id": 1006, "language": "hebrew", "term": "אֲלוּמַת אוֹר", "translation": "קרן אור, גלים המשודרים בטווח צר", "example": "אלומת אור האירה את החדר החשוך." },
    { "id": 1007, "language": "hebrew", "term": "אָמוֹדָאי", "translation": "צוללן", "example": "האמודאי ירד למעמקים לתקן את הצינור." },
    { "id": 1008, "language": "hebrew", "term": "אָמִיר", "translation": "צמרת, הענפים העליונים בעץ", "example": "הציפור בנתה קן באמיר העץ." },
    { "id": 1009, "language": "hebrew", "term": "אֲמַתְלָה", "translation": "תירוץ, סיבה לא אמיתית", "example": "הוא הגיע מאוחר באמתלה שהיה פקק תנועה." },
    { "id": 1010, "language": "hebrew", "term": "אָסָם", "translation": "מחסן תבואה", "example": "התבואה נשמרה באסם כדי שתספיק לחורף." },
    { "id": 1011, "language": "hebrew", "term": "אָצְבָּעוֹן", "translation": "כיסוי מגן לאצבע בשעת תפירה", "example": "החייט שם אצבעון כדי לא להידקר מהמחט." },
    { "id": 1012, "language": "hebrew", "term": "אֶקְרָן", "translation": "מסך, מִרְקע", "example": "הסרט הוקרן על אקרן ענק." },
    { "id": 1013, "language": "hebrew", "term": "אָרִיג", "translation": "בד", "example": "השמלה תפורה מאריג איכותי." },
    { "id": 1014, "language": "hebrew", "term": "אַרְכִיב", "translation": "ארכיון, מקום אכסון למסמכים", "example": "המסמכים הישנים נשמרו בארכיב." },
    { "id": 1015, "language": "hebrew", "term": "אֲרָעִי", "translation": "זמני", "example": "הם הקימו מחנה ארעי ללילה." },
    { "id": 1016, "language": "hebrew", "term": "אֶשְׁכּוֹל", "translation": "צרור של פירות או דברים המחוברים יחד", "example": "קנינו אשכול ענבים מתוק." },
    { "id": 1017, "language": "hebrew", "term": "בֵּאוּר", "translation": "הסבר, פרשנות", "example": "הספר כולל ביאור למילים קשות." },
    { "id": 1018, "language": "hebrew", "term": "בְּגִלּוּפִין", "translation": "במצב של שכרות קלה", "example": "הוא חזר מהמסיבה בגילופין." },
    { "id": 1019, "language": "hebrew", "term": "בְּגַפּוֹ", "translation": "לבדו, ללא בן זוג", "example": "הוא הגיע לאירוע בגפו." },
    { "id": 1020, "language": "hebrew", "term": "בּוּרְסְקִי", "translation": "מעבד עורות", "example": "הבורסקי עיבד את עור הפרה." },
    { "id": 1021, "language": "hebrew", "term": "בּוֹשֵׁשׁ", "translation": "התמהמה, איחר לבוא", "example": "האוטובוס בושש לבוא." },
    { "id": 1022, "language": "hebrew", "term": "בִּיּוּת", "translation": "אילוף, הפיכה לביתי", "example": "האדם עסק בביות של חיות בר." },
    { "id": 1023, "language": "hebrew", "term": "בֵּרָא", "translation": "כרת עצים, עקר", "example": "הקבלן בירא את היער לבנייה." },
    { "id": 1024, "language": "hebrew", "term": "בֵּית בַּד", "translation": "מקום לייצור שמן זית", "example": "בחנוכה ביקרנו בבית בד." },
    { "id": 1025, "language": "hebrew", "term": "בֵּית מַרְזַח", "translation": "פאב, מסבאה", "example": "המלחים שתו בבית המרזח." },
    { "id": 1026, "language": "hebrew", "term": "בַּלָּן", "translation": "עובד בבית מרחץ", "example": "הבלן חילק מגבות לנוחצים." },
    { "id": 1027, "language": "hebrew", "term": "בְּמַפְגִּיעַ", "translation": "באופן בוטה, בתקיפות", "example": "הוא דרש את כספו במפגיע." },
    { "id": 1028, "language": "hebrew", "term": "בַּעֲלִיל", "translation": "באופן ברור, ללא ספק", "example": "הטעות הייתה ברורה בעליל." },
    { "id": 1029, "language": "hebrew", "term": "בְּפֻמְבֵּי", "translation": "באופן גלוי, לעיני כל", "example": "הוא התנצל בפומבי על דבריו." },
    { "id": 1030, "language": "hebrew", "term": "בָּצִיר", "translation": "קטיף ענבים", "example": "הבציר מתחיל בקיץ." },
    { "id": 1031, "language": "hebrew", "term": "גָּדָה", "translation": "שפת הנהר / קצה הכלי", "example": "הנהר עלה על גדותיו." },
    { "id": 1032, "language": "hebrew", "term": "גָּהַר", "translation": "התכופף, השתופף", "example": "הוא גהר מעל המסמכים." },
    { "id": 1033, "language": "hebrew", "term": "גְּזוּזְטְרָה", "translation": "מרפסת חיצונית", "example": "עמדנו בגזוזטרה והבטנו לנוף." },
    { "id": 1034, "language": "hebrew", "term": "גְּזִיר", "translation": "חתיכה שנגזרה", "example": "הוא שמר גזיר עיתון למזכרת." },
    { "id": 1035, "language": "hebrew", "term": "גִּלְעֵן", "translation": "הוציא את הגרעין מהפרי", "example": "הטבח גילען את הזיתים." },
    { "id": 1036, "language": "hebrew", "term": "גַּרְגְּרָן", "translation": "זללן", "example": "הגרגרן אכל את כל העוגה לבד." },
    { "id": 1037, "language": "hebrew", "term": "גַּת", "translation": "מקום לדריכת ענבים ליין", "example": "היין זרם בתעלות הגת." },
    { "id": 1038, "language": "hebrew", "term": "דָּגָה", "translation": "שם כולל לדגים", "example": "הדגה בים התיכון מתמעטת." },
    { "id": 1039, "language": "hebrew", "term": "דּוֹבֵב", "translation": "גרם למישהו לדבר", "example": "החוקר דובב את הנחקר." },
    { "id": 1040, "language": "hebrew", "term": "דִּידַקְטִי", "translation": "קשור להוראה, חינוכי", "example": "זהו משחק דידקטי ללימוד חשבון." },
    { "id": 1041, "language": "hebrew", "term": "דֵּרָבוֹן", "translation": "עידוד לפעולה, המרצה", "example": "המנהל עסק בדרבון העובדים." },
    { "id": 1042, "language": "hebrew", "term": "הִבְלִיג", "translation": "התאפק, ריסן את עצמו", "example": "הוא הבליג על העלבון ולא הגיב." },
    { "id": 1043, "language": "hebrew", "term": "הִגֵּר", "translation": "עבר מארץ אחת לאחרת", "example": "הוא היגר לארצות הברית בצעירותו." },
    { "id": 1044, "language": "hebrew", "term": "הֲדוֹם", "translation": "שרפרף נמוך לרגליים", "example": "היא הניחה רגליה על ההדום." },
    { "id": 1045, "language": "hebrew", "term": "הֶדְיוֹט", "translation": "אדם פשוט, חסר ידע בתחום מסוים", "example": "ברפואה אני הדיוט גמור." },
    { "id": 1046, "language": "hebrew", "term": "הִטְמִיעַ", "translation": "החדיר, ספג, הפנים", "example": "המורה הטמיע ערכים בתלמידים." },
    { "id": 1047, "language": "hebrew", "term": "הִסָּה", "translation": "השתיק", "example": "הוא היסה את הקהל הרועש." },
    { "id": 1048, "language": "hebrew", "term": "הִכְבִּיר בְּמִילִים", "translation": "דיבר באריכות יתרה", "example": "הנואם הכביר במילים ושיעמם." },
    { "id": 1049, "language": "hebrew", "term": "הִכְחִישׁ", "translation": "טען שמשהו אינו נכון", "example": "החשוד הכחיש את המעשים." },
    { "id": 1050, "language": "hebrew", "term": "הַס", "translation": "שקט!", "example": "הס! אל תעירו את התינוק." },
    { "id": 1051, "language": "hebrew", "term": "הִסְכִּית", "translation": "הקשיב, האזין", "example": "הסכת ושמע לדבריי." },
    { "id": 1052, "language": "hebrew", "term": "הִסְלִים", "translation": "החריף, הקצין", "example": "המצב הביטחוני הסלים." },
    { "id": 1053, "language": "hebrew", "term": "הִסְמִיךְ", "translation": "נתן סמכות / הפך לסמיך", "example": "המנהל הסמיך אותו לחתום בשמו." },
    { "id": 1054, "language": "hebrew", "term": "הֶעֱלָה אֲרוּכָה", "translation": "הבריא, הפצע הגליד", "example": "הפצע העלה ארוכה במהרה." },
    { "id": 1055, "language": "hebrew", "term": "הִפְלִיג בְּשִׁבְחוֹ", "translation": "שיבח אותו מאוד", "example": "המנהל הפליג בשבחו של העובד." },
    { "id": 1056, "language": "hebrew", "term": "הִצְפִין", "translation": "החביא / נע צפונה", "example": "הוא הצפין את המטמון באדמה." },
    { "id": 1057, "language": "hebrew", "term": "הֵקִיץ", "translation": "התעורר משנתו", "example": "הוא הקיץ עם הזריחה." },
    { "id": 1058, "language": "hebrew", "term": "הִשְׁחִיז", "translation": "חידד (סכין או חרב)", "example": "הקצב השחיז את הסכין." },
    { "id": 1059, "language": "hebrew", "term": "הִשְׁתָּאוּת", "translation": "פליאה, תדהמה", "example": "הקהל הביט בקוסם בהשתאות." },
    { "id": 1060, "language": "hebrew", "term": "הִתְבַּשֵּׂר", "translation": "קיבל בשורה טובה", "example": "הוא התבשר על הולדת בנו." },
    { "id": 1061, "language": "hebrew", "term": "הִתְגּוֹדֵד", "translation": "התקהל, התאסף", "example": "הקהל התגודד בכיכר." },
    { "id": 1062, "language": "hebrew", "term": "הִתְחַלָּה", "translation": "העמיד פני חולה", "example": "החייל התחלה כדי לנוח." },
    { "id": 1063, "language": "hebrew", "term": "הִתְחַסֵּד", "translation": "העמיד פני צדיק", "example": "אל תתחסד, אתה לא תמים." },
    { "id": 1064, "language": "hebrew", "term": "הִתִּיר", "translation": "פתח קשר / הרשה", "example": "הוא התיר את הקשר בחבל." },
    { "id": 1065, "language": "hebrew", "term": "הִתְכַּתֵּשׁ", "translation": "נאבק, רב מכות", "example": "הילדים התכתשו בחצר." },
    { "id": 1066, "language": "hebrew", "term": "הִתְמוֹגֵג", "translation": "התענג, נהנה מאוד", "example": "הסב התמוגג מנכדיו." },
    { "id": 1067, "language": "hebrew", "term": "הִתַּמֵּר", "translation": "התרומם כלפי מעלה", "example": "עשן היתמר מהארובה." },
