    { "id": 1076, "language": "hebrew", "term": "זְרָד", "translation": "ענף דק", "example": "אספנו זרדים למדורה." },
    { "id": 1077, "language": "hebrew", "term": "זָרָה מֶלַח עַל הַפְּצָעִים", "translation": "הוסיף על צערו", "example": "דבריו רק זרו מלח על הפצעים." },
    { "id": 1078, "language": "hebrew", "term": "חָס", "translation": "ריחם", "example": "השופט חס על הנאשם." },
    { "id": 1079, "language": "hebrew", "term": "חֲרִי אַף", "translation": "כעס, זעם", "example": "הוא הגיב בחרי אף על העלבון." },
    { "id": 1080, "language": "hebrew", "term": "חָרִישׁ", "translation": "עיבוד האדמה במחרשה", "example": "האיכר יצא לחריש בשדה." },
    { "id": 1081, "language": "hebrew", "term": "חֲרִישִׁי", "translation": "שקט", "example": "היה שם שקט חרישי." },
    { "id": 1082, "language": "hebrew", "term": "חָרַךְ", "translation": "שרף קלות / חריץ בקיר", "example": "האש חרכה את קצות הנייר." },
    { "id": 1083, "language": "hebrew", "term": "טָוָה", "translation": "שזר חוטים / חיבר", "example": "העכביש טווה קורים." },
    { "id": 1084, "language": "hebrew", "term": "טְלָאי", "translation": "חתיכת בד לתיקון קרע", "example": "היא תפרה טלאי על המכנסיים." },
    { "id": 1085, "language": "hebrew", "term": "טְרָשִׁים", "translation": "אדמה סלעית", "example": "הם הלכו בשדה טרשים קשה להליכה." },
    { "id": 1086, "language": "hebrew", "term": "יָגֵעַ", "translation": "עייף, תשוש", "example": "הוא היה יגע מהדרך הארוכה." },
    { "id": 1087, "language": "hebrew", "term": "יָד רוֹחֶצֶת יָד", "translation": "שמור לי ואשמור לך", "example": "בפוליטיקה יד רוחצת יד." },
    { "id": 1088, "language": "hebrew", "term": "יְקִיצָה", "translation": "התעוררות משינה", "example": "היקיצה בבוקר הייתה נעימה." },
    { "id": 1089, "language": "hebrew", "term": "יַרְכָּתַיִים", "translation": "החלק האחורי של ספינה", "example": "עמדנו בירכתי הספינה והבטנו לאחור." },
    { "id": 1090, "language": "hebrew", "term": "כְּבַד לָשׁוֹן", "translation": "מגמגם, מתקשה בדיבור", "example": "משה היה כבד פה וכבד לשון." },
    { "id": 1091, "language": "hebrew", "term": "כִּחֵד", "translation": "הסתיר, לא גילה את האמת", "example": "הוא לא כיחד ממני דבר." },
    { "id": 1092, "language": "hebrew", "term": "כִּילָה", "translation": "סיים / השמיד", "example": "האש כילתה את היער." },
    { "id": 1093, "language": "hebrew", "term": "כַּנָּה", "translation": "בסיס, מעמד", "example": "הפסל עמד על כנה יציבה." },
    { "id": 1094, "language": "hebrew", "term": "כְּסָיָה", "translation": "כפפה", "example": "היא לבשה כסיה לבנה." },
    { "id": 1095, "language": "hebrew", "term": "כְּרַךְ", "translation": "עיר גדולה", "example": "תל אביב היא כרך סואן." },
