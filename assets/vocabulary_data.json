    { "id": 1069, "language": "hebrew", "term": "הִתְנַכֵּר", "translation": "העמיד פנים כזר, התעלם", "example": "הוא התנכר לחבריו הישנים." },
    { "id": 1070, "language": "hebrew", "term": "הִתְנַצֵּחַ", "translation": "התווכח", "example": "הם התנצחו שעות על הפוליטיקה." },
    { "id": 1071, "language": "hebrew", "term": "הִתְעַמֵּר", "translation": "התעלל, התאכזר", "example": "המפקד התעמר בפקודיו." },
    { "id": 1072, "language": "hebrew", "term": "הִתְעַרְטֵל", "translation": "פשט את בגדיו", "example": "הוא התערטל לפני שנכנס למים." },
    { "id": 1073, "language": "hebrew", "term": "הִתְרָה", "translation": "הזהיר", "example": "השוטר התרה בנהג לפני שנתן דוח." },
    { "id": 1074, "language": "hebrew", "term": "הִתְרָצָה", "translation": "הסכים לאחר שכנוע", "example": "לבסוף הוא התרצה ובא איתנו." },
